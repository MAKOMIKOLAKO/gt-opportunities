# Copy this into the Railway dashboard's environment variable settings for
# the backend service (real values — never commit a filled-in .env).

# --- Database ---
# Path to the SQLite file. In Railway, mount a Volume on the backend service
# (e.g. at /data) and point this at a file inside it, so data survives
# redeploys and restarts. Example: /data/db.sqlite
# Locally this defaults to backend/data/db.sqlite if unset.
DB_PATH=/data/db.sqlite

# --- Admin auth ---
# Shared-password admin login (backend/src/lib/auth.ts). If unset, a random
# username/password/secret is generated at process startup instead — fine
# for local dev, but useless in production because it changes on every
# restart and invalidates all admin sessions. Set real values here.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Secret used to HMAC-sign admin session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- Server ---
# Railway injects PORT automatically at deploy time — do not set this
# manually in the dashboard, it's listed here only for local reference.
PORT=3000
NODE_ENV=production
