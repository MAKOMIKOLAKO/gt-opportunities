# Copy this into the Vercel dashboard's Environment Variables settings for
# the project (real values — never commit a filled-in .env). This project
# deploys entirely on Vercel: the static frontend (frontend/public) and the
# `/api` serverless functions from a single project — there is no second
# host.

# --- Database (Neon Postgres) ---
# Neon's *pooled* connection string (Project -> Connect -> "Pooled
# connection", the one with `-pooler` in the hostname). Required — every
# /api handler, the migration runner, and the standalone scraper scripts
# read this. Pooled (not direct) is important: Vercel functions are
# short-lived and can open many concurrent connections, which a direct
# Postgres connection limit will exhaust quickly.
#   postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# --- Admin auth ---
# Shared-password admin login (backend/src/lib/auth.ts). If unset, a random
# username/password/secret is generated at process startup instead — fine
# for local dev, but useless in production because every cold start would
# rotate it and invalidate all admin sessions. Set real values here.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Secret used to HMAC-sign admin session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

NODE_ENV=production
