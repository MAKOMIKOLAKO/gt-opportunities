# frontend/server.js is now LOCAL-DEV ONLY. In production this project
# deploys as a single Vercel project (see root vercel.json + DEPLOY.md): the
# static files in frontend/public are served directly by Vercel and
# `/api/*` is routed to the serverless functions in /api — there is no
# separate frontend service or BACKEND_URL to configure on Vercel.
#
# These vars only matter if you run `node frontend/server.js` locally
# against a backend running elsewhere (e.g. `vercel dev` bound to a
# different port).
BACKEND_URL=http://localhost:3000
PORT=8080
