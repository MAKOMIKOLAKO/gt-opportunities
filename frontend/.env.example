# Env vars for the frontend service (frontend/server.js), if deployed as its
# own Railway service with Root Directory set to `frontend/`. Copy into that
# service's dashboard env var settings with real values.

# Public URL of the backend Railway service (Settings -> Networking ->
# Public Networking on that service). Must be reachable from the frontend
# service, e.g. https://backend-production-xxxx.up.railway.app
BACKEND_URL=

# Railway injects PORT automatically at deploy time — do not set this
# manually in the dashboard, it's listed here only for local reference.
PORT=8080
